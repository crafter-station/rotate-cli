---
/**
 * Chess king silhouette — single dark focal point offset to one side,
 * low opacity so it reads as a watermark on the parchment.
 */
---

<svg
  viewBox="0 0 120 160"
  fill="currentColor"
  aria-hidden="true"
  class="pointer-events-none"
>
  <!-- cross on top -->
  <rect x="56" y="6" width="8" height="22" rx="1" />
  <rect x="48" y="12" width="24" height="8" rx="1" />

  <!-- crown -->
  <path d="M36 34 L60 24 L84 34 L78 50 L42 50 Z" />

  <!-- neck -->
  <rect x="50" y="50" width="20" height="10" />

  <!-- body taper -->
  <path d="M40 60 L80 60 L74 96 L46 96 Z" />

  <!-- mid flare -->
  <rect x="34" y="96" width="52" height="8" rx="1" />

  <!-- wider body -->
  <path d="M36 104 L84 104 L78 136 L42 136 Z" />

  <!-- base -->
  <rect x="26" y="136" width="68" height="12" rx="1" />
  <rect x="20" y="148" width="80" height="8" rx="1" />
</svg>
