---
/**
 * Theme-aware wrapper. Renders two slots (one per theme) and CSS
 * hides the off-theme one based on [data-theme] on <html>. Zero
 * hydration needed since both variants render in SSR.
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<span class:list={["logo-themed", className]}>
  <span class="logo-light">
    <slot name="light" />
  </span>
  <span class="logo-dark">
    <slot name="dark" />
  </span>
</span>

<style is:global>
  .logo-themed {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .logo-themed > span {
    display: inline-flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
  }
  .logo-themed > span > svg {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
  }
  html[data-theme="dark"] .logo-themed .logo-light { display: none; }
  html:not([data-theme="dark"]) .logo-themed .logo-dark { display: none; }
</style>
