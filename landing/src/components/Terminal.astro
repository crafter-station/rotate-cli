---
/**
 * Terminal code block. Accepts either:
 *   - a `lines` array of pre-formatted HTML strings (one per line)
 *   - raw HTML via the slot (legacy, whitespace-fragile)
 *
 * Prefer `lines` because Astro collapses whitespace inside <pre><slot /></pre>
 * when the slot content is JSX-like (mixed text + elements), breaking
 * multi-line code blocks at build time.
 */

interface Props {
  title?: string;
  lines?: string[];
}

const { title, lines } = Astro.props;
const joined = lines?.join("\n");
---

<div class="terminal relative">
  {
    title && (
      <div class="absolute top-2 right-3 label text-xs text-parchment-shadow">
        {title}
      </div>
    )
  }
  {
    joined !== undefined ? (
      <pre class="m-0" set:html={joined} />
    ) : (
      <pre class="m-0"><slot /></pre>
    )
  }
</div>
