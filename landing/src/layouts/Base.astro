---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "rotate-cli, agent-first secrets rotation",
  description = "Local-first secrets rotation CLI. Built for the AI-native stack. Zero servers, agent mode with hard guardrails, incident mode for vendor breaches.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("rotate-cli-theme");
          const theme =
            saved ??
            (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light");
          document.documentElement.setAttribute("data-theme", theme);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://rotate-cli.crafter.run" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
    <Analytics />
  </body>
</html>
